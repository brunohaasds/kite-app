DATABASE_URL="postgresql://user:password@host:5432/kite_app?schema=public"
AUTH_SECRET="your-secret-here"
# Opcional: sobrescreve o segredo derivado de AUTH_SECRET para /api/internal/session-user
# INTERNAL_SESSION_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# Opcional: hero /spots — URL ou /caminho em public (default: CDN em src/lib/branding.ts)
# NEXT_PUBLIC_EKITE_SPOTS_HERO_BG="/marketing/spots.jpg"
RESEND_API_KEY="your-resend-api-key"
